[submodule "SDL"]
	path = sdl3-src/SDL
	url = https://github.com/libsdl-org/SDL
[submodule "SDL_image"]
	path = sdl3-image-src/SDL_image
	url = https://github.com/libsdl-org/SDL_image
[submodule "SDL_ttf"]
	path = sdl3-ttf-src/SDL_ttf
	url = https://github.com/libsdl-org/SDL_ttf
[submodule "SDL_mixer"]
	path = sdl3-mixer-src/SDL_mixer
	url = https://github.com/libsdl-org/SDL_mixer
[submodule "SDL_net"]
	path = sdl3-net-src/SDL_net
	url = https://github.com/libsdl-org/SDL_net
[submodule "SDL_sound"]
	path = sdl3-sound-src/SDL_sound
	url = https://github.com/icculus/SDL_sound
